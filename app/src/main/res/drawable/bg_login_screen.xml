<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base Pink + White Gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#ff3f4f"
                android:centerColor="#ff9fa7"
                android:endColor="#FFFFFF" />
        </shape>
    </item>


    <!-- Decorative ring, top-right -->
    <item
        android:width="260dp"
        android:height="260dp"
        android:gravity="top|end"
        android:right="-90dp"
        android:top="-90dp">

        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />

            <stroke
                android:width="30dp"
                android:color="#22FFFFFF" />
        </shape>

    </item>


    <!-- Decorative filled glow, bottom-left -->
    <item
        android:width="320dp"
        android:height="320dp"
        android:gravity="bottom|start"
        android:bottom="-140dp"
        android:left="-120dp">

        <shape android:shape="oval">

            <gradient
                android:type="radial"
                android:gradientRadius="160dp"
                android:startColor="#33FFFFFF"
                android:endColor="#00FFFFFF" />

        </shape>

    </item>


    <!-- Small ring accent, mid-right -->
    <item
        android:width="120dp"
        android:height="120dp"
        android:gravity="center_vertical|end"
        android:right="20dp">

        <shape android:shape="oval">

            <solid android:color="@android:color/transparent" />

            <stroke
                android:width="10dp"
                android:color="#33FFFFFF" />

        </shape>

    </item>


    <!-- Extra pink glow -->
    <item
        android:width="220dp"
        android:height="220dp"
        android:gravity="bottom|end"
        android:right="-80dp"
        android:bottom="-80dp">

        <shape android:shape="oval">

            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:startColor="#55FF5FA2"
                android:endColor="#00FF5FA2" />

        </shape>

    </item>


</layer-list>